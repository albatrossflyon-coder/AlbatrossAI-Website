# ============================================================
# Builder Buddy — Provider Config
# Copy this to .env and fill in your values
# ============================================================

# AI Provider — swap model string to change provider, no code changes needed
# Gemini (free tier):   gemini/gemini-1.5-flash
# Anthropic:            claude-haiku-4-5-20251001
# OpenAI:               gpt-3.5-turbo
# OpenRouter:           openrouter/google/gemini-flash-1.5
LLM_MODEL=gemini/gemini-1.5-flash
LLM_API_KEY=your_key_here

# Bot identity — customize per client deployment
BOT_NAME=Builder Buddy
FREE_QUERY_LIMIT=50

# Lead dashboard — visit /leads?password=yourpassword to view leads
# Leave empty to disable password protection
DASHBOARD_PASSWORD=
